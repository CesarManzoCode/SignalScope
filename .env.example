# ================================

# SignalScope Environment Variables

# ================================

# ----------------

# OpenAI

# ----------------

# Your OpenAI API key.

# Required if using OpenAIClient.

OPENAI_API_KEY=your_openai_api_key_here

# ----------------

# Anthropic

# ----------------

# Your Anthropic API key.

# Required if using AnthropicClient.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------

# Ollama (Local LLM)

# ----------------

# Base URL for your local Ollama server.

# Default is usually http://localhost:11434

OLLAMA_URL=http://localhost:11434

# ----------------

# Default Model

# ----------------

# Default model used by LLM clients if no model is specified.

# Examples:

# - OpenAI: gpt-4.1-mini

# - Anthropic: claude-3-opus-20240229

# - Ollama: llama3

DEFAULT_MODEL=gpt-4.1-mini

# ----------------

# Optional Settings (Future Use)

# ----------------

# You can add future configuration here such as:

# TIMEOUT=10

# MAX_ITEMS=20
